# Backend
DATABASE_URL=postgresql://rydberg:rydberg@postgres:5432/rydberg
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Google Sign-In (separate OAuth client from the Gmail integration above).
# Create at https://console.cloud.google.com/apis/credentials with an
# "Authorized redirect URI" matching GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/callback
# Random long string used to sign the OAuth handshake cookie, e.g.:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET_KEY=
# You (full access). Must also be listed in/implied by ALLOWED_EMAILS.
OWNER_EMAIL=
# Comma-separated list of friends' Google emails allowed to log in (read-only).
ALLOWED_EMAILS=
# Set to "true" once served over HTTPS so the session cookie requires it.
COOKIE_SECURE=false
# Used for CORS and for redirecting back after login/logout.
FRONTEND_URL=http://localhost:5173

# LLM inference (vLLM, OpenAI-compatible). Backend reaches vLLM by service
# name over the compose network. Note: vLLM is behind the 'inference'
# profile, so it must be started for this to resolve:
#   docker compose --profile inference up -d
LLM_BASE_URL=http://vllm:8000/v1
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct-AWQ

# Frontend (browser-side fetches, so localhost not service name)
VITE_API_BASE_URL=http://localhost:8080

# Postgres
POSTGRES_USER=rydberg
POSTGRES_PASSWORD=rydberg
POSTGRES_DB=rydberg

# vLLM / HuggingFace — set HF_HOME to a real path on the host with space
# for model weights (e.g. /data/hf-cache). Token from huggingface.co/settings/tokens
HF_HOME=/data/hf-cache
HUGGING_FACE_HUB_TOKEN=